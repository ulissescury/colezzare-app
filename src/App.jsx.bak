          <div style={{marginBottom:4}}>
            <div style={{fontSize:11,color:"#aaa",marginBottom:8}}>📦 Condição padrão ao anunciar</div>
            <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
              {[{v:"new",l:"🌟 Novo"},{v:"like_new",l:"✨ Seminovo"},{v:"used",l:"📦 Usado"},{v:"incomplete",l:"⚠️ Incompleto"}].map(o=>(
                <button key={o.v} onClick={()=>setDefaultCondition(o.v)} style={{
                  padding:"6px 12px",borderRadius:20,border:"none",cursor:"pointer",fontSize:11,
                  background:defaultCondition===o.v?"#ffd700":"#ffffff10",
                  color:defaultCondition===o.v?"#000":"#888",fontWeight:defaultCondition===o.v?800:400}}>
                  {o.l}
                </button>
              ))}
            </div>
          </div>
        </div>

        {/* Privacidade */}
        <div style={{background:"#ffffff08",borderRadius:12,padding:16,marginBottom:16,
          border:"1px solid #ffffff10"}}>
          <div style={{fontSize:10,color:"#555",fontWeight:700,letterSpacing:1,marginBottom:10}}>PRIVACIDADE</div>
          <div style={{fontSize:12,color:"#888",lineHeight:1.7}}>
            Seus dados são armazenados com segurança e protegidos pela LGPD.
          </div>
        </div>

        <button onClick={save} style={{width:"100%",padding:"14px",borderRadius:12,border:"none",
          cursor:"pointer",fontSize:14,fontWeight:800,
          background: saved ? "#22c55e" : "linear-gradient(90deg,#ffd700,#ff8c00)",
          color: saved ? "#fff" : "#000",transition:"all 0.3s"}}>
          {saved ? "✓ Salvo!" : "Salvar preferências"}
        </button>
      </div>
    </div>
  );
}

